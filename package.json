{
  "name": "docdiffer",
  "version": "1.0.0",
  "description": "State-of-the-art document comparison tool for PDF, HTML, Confluence, and DOCX",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:standalone": "tsc && vite build --config vite.singlefile.config.ts",
    "build:all": "npm run build && npm run build:standalone",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "diff": "^5.1.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.0.9",
    "fuse.js": "^7.0.0",
    "htmlparser2": "^9.1.0",
    "lit-html": "^3.1.2",
    "mammoth": "^1.6.0",
    "pdfjs-dist": "^4.0.379",
    "turndown": "^7.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-singlefile": "^2.0.1"
  }
}
